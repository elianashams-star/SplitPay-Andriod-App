<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="40dp"
            android:paddingBottom="24dp">

            <TextView
                android:text="Account"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="20dp">

                <FrameLayout
                    android:layout_width="132dp"
                    android:layout_height="132dp"
                    android:background="@drawable/bg_avatar_halo"
                    android:elevation="12dp">

                    <FrameLayout
                        android:layout_width="104dp"
                        android:layout_height="104dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_photo_ring"
                        android:padding="4dp">

                        <TextView
                            android:id="@+id/profileInitialText"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:background="@drawable/bg_icon_circle"
                            android:backgroundTint="@color/avatar_blue"
                            android:text="?" />

                        <ImageView
                            android:id="@+id/profilePhotoImage"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:background="@drawable/bg_icon_circle"
                            android:clipToOutline="true"
                            android:outlineProvider="background"
                            android:visibility="gone" />

                    </FrameLayout>

                </FrameLayout>

            </LinearLayout>

            <!-- Profile info card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_profile_card"
                android:padding="20dp"
                android:elevation="8dp"
                android:layout_marginBottom="28dp">

                <TextView
                    android:id="@+id/profileNameText"
                    android:text="Not signed in"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <TextView
                    android:id="@+id/profileEmailText"
                    android:text=""
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:id="@+id/signedInActionsRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/changePhotoBtn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_tile_blue"
                        android:padding="14dp"
                        android:elevation="4dp"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:text="Change Photo"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/signOutBtn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_tile_red"
                        android:padding="14dp"
                        android:elevation="4dp"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:text="Sign Out"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/accent_red"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                    </LinearLayout>

                </LinearLayout>

                <Button
                    android:id="@+id/googleSignInBtn"
                    android:text="Sign in with Google"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:backgroundTint="@color/accent_green"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:visibility="gone" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/paymentMethodsSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:text="Payment Methods"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/paymentMethodsRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/addPaymentMethodBtn"
                    android:text="+  Add Payment Method"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:backgroundTint="@color/card_dark"
                    android:textColor="@color/accent_green"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:id="@+id/addMethodForm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_transaction_card"
                    android:padding="18dp"
                    android:elevation="6dp"
                    android:visibility="gone"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:text="Type"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_tabs_container"
                        android:padding="6dp"
                        android:layout_marginBottom="16dp">

                        <Button
                            android:id="@+id/typeCreditBtn"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:text="Credit"
                            android:textAllCaps="false"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:background="@drawable/bg_tab_selected"
                            android:backgroundTint="@null"
                            android:stateListAnimator="@null" />

                        <Button
                            android:id="@+id/typeDebitBtn"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:text="Debit"
                            android:textAllCaps="false"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_secondary"
                            android:background="@drawable/bg_tab_unselected"
                            android:backgroundTint="@null"
                            android:stateListAnimator="@null"
                            android:layout_marginStart="4dp" />

                        <Button
                            android:id="@+id/typeBankBtn"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:text="Bank"
                            android:textAllCaps="false"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_secondary"
                            android:background="@drawable/bg_tab_unselected"
                            android:backgroundTint="@null"
                            android:stateListAnimator="@null"
                            android:layout_marginStart="4dp" />
                    </LinearLayout>

                    <TextView
                        android:text="Last 4 Digits"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/methodLast4Input"
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:background="@drawable/bg_input"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:hint="e.g. 4829"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:inputType="number"
                        android:maxLength="4"
                        android:importantForAutofill="no"
                        android:saveEnabled="false"
                        android:layout_marginBottom="16dp" />

                    <Button
                        android:id="@+id/savePaymentMethodBtn"
                        android:text="Save"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:backgroundTint="@color/accent_green"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:textAllCaps="false" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_transaction_card"
                    android:padding="16dp"
                    android:elevation="4dp"
                    android:layout_marginTop="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:text="Fingerprint Lock"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                        <TextView
                            android:text="Require fingerprint to open SplitPay"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <Switch
                        android:id="@+id/biometricLockSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <include layout="@layout/bottom_nav" />

</LinearLayout>