<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="68dp"
    android:orientation="horizontal"
    android:background="@color/card_dark"
    android:paddingTop="10dp"
    android:paddingBottom="8dp"
    android:gravity="center_vertical">

    <LinearLayout
        android:id="@+id/navHome"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:foreground="?attr/selectableItemBackground">

        <ImageView
            android:id="@+id/navHomeIcon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_nav_home" />

        <TextView
            android:id="@+id/navHomeText"
            android:text="Home"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="3dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navGroups"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:foreground="?attr/selectableItemBackground">

        <ImageView
            android:id="@+id/navGroupsIcon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_nav_groups" />

        <TextView
            android:id="@+id/navGroupsText"
            android:text="Groups"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="3dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navAdd"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:foreground="?attr/selectableItemBackground">

        <LinearLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_nav_add_circle"
            android:gravity="center">

            <TextView
                android:text="+"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <TextView
            android:id="@+id/navAddText"
            android:text="Add"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/accent_green"
            android:layout_marginTop="3dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navAccount"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:foreground="?attr/selectableItemBackground">

        <ImageView
            android:id="@+id/navAccountIcon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_nav_account" />

        <TextView
            android:id="@+id/navAccountText"
            android:text="Account"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="3dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

</LinearLayout>