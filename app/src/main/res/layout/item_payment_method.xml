<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="200dp"
    android:layout_marginBottom="16dp"
    android:elevation="10dp">

    <LinearLayout
        android:id="@+id/cardBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/bg_card_credit"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:id="@+id/cardChip"
                android:layout_width="34dp"
                android:layout_height="26dp"
                android:background="@drawable/bg_chip" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/cardTypeLabel"
                android:text="CREDIT"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#E6F1FB"
                android:letterSpacing="0.1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <TextView
            android:id="@+id/cardNumberText"
            android:text="•••• •••• •••• 0000"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:letterSpacing="0.08"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/cardHolderLabel"
                    android:text="CARD HOLDER"
                    android:textSize="9sp"
                    android:textColor="#93C5FD"
                    android:letterSpacing="0.05"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:id="@+id/cardHolderText"
                    android:text="NAME"
                    android:textSize="13sp"
                    android:textColor="@android:color/white"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/cardBrandText"
                android:text="Visa"
                android:textSize="16sp"
                android:textStyle="bold|italic"
                android:textColor="@android:color/white"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <LinearLayout
                android:id="@+id/mastercardDots"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone">

                <View
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:background="@drawable/bg_mastercard_red" />

                <View
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginStart="-8dp"
                    android:background="@drawable/bg_mastercard_orange" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <ImageButton
        android:id="@+id/deleteMethodBtn"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="top|end"
        android:layout_margin="10dp"
        android:src="@android:drawable/ic_menu_delete"
        android:background="@drawable/bg_delete_circle"
        android:padding="6dp" />

</FrameLayout>